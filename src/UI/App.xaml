<Application
    x:Class="UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:UI.Converters"
    xmlns:local="clr-namespace:UI"
    DispatcherUnhandledException="Application_DispatcherUnhandledException">
    <Application.Resources>

        <ResourceDictionary>

            <converters:WindowPercentConverter x:Key="WindowPercentConverter" />
            <converters:MonitorStatusToBoolConverter x:Key="MonitorStatusToBoolConverter" />
            <!--<FontFamily x:Key="Main">Cascadia Code</FontFamily>-->
            <FontFamily x:Key="Main">pack://application:,,,/Themes/Fonts/#Cascadia Code</FontFamily>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Icons.xaml" />
                <ResourceDictionary Source="/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Themes/Styles.xaml" />
                <ResourceDictionary Source="/Themes/ComboBox.xaml" />
                <ResourceDictionary Source="/Themes/ComboBoxItem.xaml" />
                <ResourceDictionary Source="/Themes/Scrollviewer.xaml" />
                <ResourceDictionary Source="/Themes/DataGrid.xaml" />







            </ResourceDictionary.MergedDictionaries>



        </ResourceDictionary>
    </Application.Resources>

</Application>
